{
  "auth": {
    "profiles": {
      "vertex:default": {
        "provider": "vertex",
        "project_id": "YOUR_PROJECT_ID",
        "region": "us-east5"
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "vertex/gemini-2.5-flash"
      }
    },
    "list": [
      {
        "id": "main",
        "model": "vertex/gemini-2.5-flash",
        "heartbeat": {
          "enabled": true,
          "intervalMs": 3600000
        }
      }
    ]
  },
  "_comment": "Uses Vertex AI (GCP). Run 'gcloud auth application-default login' to authenticate. Change region if Claude isn't available in us-east5 for your project."
}
