{
  "gateway": {
    "mode": "local"
  },
  "auth": {
    "profiles": {
      "vertex:default": {
        "provider": "vertex",
        "mode": "oauth"
      }
    }
  },
  "memory": {
    "backend": "qmd",
    "qmd": {
      "paths": [
        { "name": "vault-people", "path": "~/Documents/Obsidian Vault/People", "pattern": "**/*.md" },
        { "name": "vault-clients", "path": "~/Documents/Obsidian Vault/Clients", "pattern": "**/*.md" },
        { "name": "transcripts", "path": "~/.openclaw/workspace/transcriptions", "pattern": "**/*.txt" }
      ],
      "sessions": { "enabled": true }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "vertex/gemini-2.5-flash"
      }
    },
    "list": [
      {
        "id": "main",
        "model": "vertex/gemini-2.5-flash"
      }
    ]
  }
}
